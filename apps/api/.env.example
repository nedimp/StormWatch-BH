PORT=3001
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# PostgreSQL (used when switching to DrizzleAlertRepository)
DATABASE_URL=postgresql://stormwatch:stormwatch@localhost:5432/stormwatch_bh

# Redis (used for production event bus and caching)
REDIS_URL=redis://localhost:6379

# OpenWeatherMap API key
OPENWEATHERMAP_API_KEY=your_api_key_here

# CORS
CORS_ORIGIN=http://localhost:5173

# JWT (for future auth)
JWT_SECRET=change_this_in_production_at_least_32_chars
