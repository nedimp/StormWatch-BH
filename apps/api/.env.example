# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string — observations + subscriptions are persisted here
DATABASE_URL=postgresql://stormwatch_user:yourpassword@localhost:5432/stormwatch_bh

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
# Create a Gmail App Password: https://myaccount.google.com/apppasswords
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# ── Worker authentication ─────────────────────────────────────────────────────
# Shared secret between the API and weather-worker.
# Generate with: openssl rand -hex 32
WORKER_SECRET=change_this_to_a_64_char_random_hex_string

# ── Frontend URLs ─────────────────────────────────────────────────────────────
DASHBOARD_URL=http://localhost:5173/dashboard
API_BASE_URL=http://localhost:3001

# ── Static frontend (production only) ────────────────────────────────────────
# Path to the built React app — leave empty for local dev (Vite handles it)
# STATIC_PATH=/path/to/apps/web/dist
