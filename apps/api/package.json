{
  "name": "@stormwatch/api",
  "version": "1.0.0",
  "private": true,
  "description": "REST API + WebSocket server for StormWatch BH",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist",
    "db:migrate": "tsx src/infrastructure/database/migrate.ts",
    "db:seed": "tsx src/infrastructure/database/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/static": "^6.12.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^3.0.0",
    "@fastify/websocket": "^8.3.1",
    "@stormwatch/application": "workspace:*",
    "@stormwatch/domain": "workspace:*",
    "@types/nodemailer": "^8.0.1",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.30.5",
    "fastify": "^4.26.0",
    "nodemailer": "^9.0.3",
    "pino": "^8.19.0",
    "postgres": "^3.4.3",
    "redis": "^4.6.13",
    "uuid": "^9.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/uuid": "^9.0.8",
    "@vitest/coverage-v8": "^1.4.0",
    "drizzle-kit": "^0.20.14",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.7.2",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
