{
  "name": "@stormwatch/weather-worker",
  "version": "1.0.0",
  "private": true,
  "description": "Background worker \u2014 polls OpenWeatherMap for BiH stations and submits observations",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/worker.ts",
    "start": "node dist/worker.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@stormwatch/application": "workspace:*",
    "@stormwatch/domain": "workspace:*",
    "dotenv": "^16.4.5",
    "node-cron": "^3.0.3",
    "pino": "^8.19.0",
    "undici": "^6.11.1"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.7.2",
    "typescript": "^5.4.0",
    "vitest": "^1.6.1"
  }
}